# Paper Memory — Git除外設定

# --- 環境変数・機密情報 ---
.env
.venv/
venv/
ENV/
docs/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.tox/

# --- データベース & ベクターストア ---
# ChromaDB & Logs
.chromadb/
logs/
*.db
*.db-shm
*.db-wal

# --- 論文・データ・一時ファイル ---
# 論文PDF（個別にgit addする場合のみ追跡）
pdf/*.pdf
# 一時作業用ディレクトリ
scratch/
_backup/
# 生成されたユーザーデータ
notes/*.json
references/*.json
extracted/
output/

# --- エディタ・OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.bak
.gemini/settings.json
*.code-workspace

# .agents/rules/ と .agents/workflows/ は他リポジトリで管理するため除外
.agents/rules/
.agents/workflows/
.agents/scratch/
